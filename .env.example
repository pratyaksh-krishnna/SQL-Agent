# ──────────────────────────────────────────────────────────
# SQL Agent — Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────

# ── PostgreSQL (stores schemas, chunks, embeddings, etc.) ──
DATABASE_URL=postgresql://user:password@localhost:5432/sql_agent

# ── OpenAI (embeddings + LLM for doc generation & agent) ──
OPENAI_API_KEY=sk-...

# ── AWS / S3 (raw file storage for uploaded tables) ──
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=my-sql-agent-uploads
